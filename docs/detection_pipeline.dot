digraph DetectionPipeline {
    node [shape=box, style="rounded,filled", fillcolor="#fff3e0", color="#f57c00", fontname="Arial", fontsize=12];
    edge [color="#f57c00", fontname="Arial", fontsize=10];
    fontname="Arial";
    rankdir=TD;
    nodesep=0.5;
    ranksep=0.7;

    subgraph cluster_input {
        label="1. Context & Inputs";
        style="rounded,filled";
        fillcolor="#f5f5f5";
        color="#bdbdbd";
        A [label="Camera Feed / Upload\n(WebRTC / Local Image)", fillcolor="#e1f5fe", color="#0288d1"];
        B [label="Image Preprocessing\n(RGB Conversion & Sizing)"];
        A -> B;
    }

    subgraph cluster_inference {
        label="2. Inference Engine";
        style="rounded,filled";
        fillcolor="#f5f5f5";
        color="#bdbdbd";
        C [label="Deep Learning Model\n(PyTorch / YOLO Segment)"];
        D [label="Mask Post-processing\n(Confidence Extraction > 0.5)"];
        E [label="Edge Refinement\n(Guided Filter / Tracking)"];
        B -> C;
        C -> D;
        D -> E [label=" Optional"];
    }

    subgraph cluster_post {
        label="3. Analysis & Measurement";
        style="rounded,filled";
        fillcolor="#f5f5f5";
        color="#bdbdbd";
        F [label="Contour Extraction\n(OpenCV findContours)", fillcolor="#e8f5e9", color="#388e3c"];
        G [label="Geometry Fitting\n(Bounding Box, Enclosing Circle)", fillcolor="#e8f5e9", color="#388e3c"];
        H [label="Real-World Calibration\n(Dynamic px to mm)"];
        I [label="Physical Characteristics\n(Area, Radius computations)"];
        
        D -> F;
        E -> F;
        F -> G;
        G -> H;
        H -> I;
    }

    subgraph cluster_ui {
        label="4. Presentation & Storage";
        style="rounded,filled";
        fillcolor="#f5f5f5";
        color="#bdbdbd";
        J [label="Web Dashboard Display\n(HTML5 Canvas UI Overlay)", fillcolor="#fce4ec", color="#c2185b"];
        K [label="Live Result Logging\n(Local History / JSON Export)", fillcolor="#fce4ec", color="#c2185b"];
        
        I -> J;
        J -> K;
    }
}
