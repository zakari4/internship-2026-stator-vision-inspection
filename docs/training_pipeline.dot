digraph DetailedTrainingPipeline {
    node [shape=box, style="solid", color="black", fillcolor="white", fontname="Arial", fontsize=11];
    edge [color="black", fontname="Arial", fontsize=10];
    fontname="Arial";
    rankdir=TD;
    compound=true;
    nodesep=0.7;
    ranksep=0.8;

    subgraph cluster_data {
        label="1. Automated Data Preparation & Augmentation";
        style="solid";
        color="black";
        
        RawData [label="Raw Data Input\n(Images + LabelMe JSON Polygons)\nDirectory: data/", shape=folder];
        Augment [label="Offline Data Augmentation (72x)\nOutputs to: outputs/augmented_data/\n - 8 Geometric (Updates coords)\n - 9 Photometric (CLAHE, Blur, Noise, etc.)"];
        Split [label="Dataset Splitting\n70% Train / 15% Val / 15% Test"];
        
        RawData -> Augment;
        Augment -> Split;
        
        subgraph cluster_format {
            label="Dataset Formats";
            style="dashed";
            PytorchDS [label="PyTorch Format\n- generates binary masks from polygons\n- Custom IndustrialDataset & collate_fn"];
            YoloDS [label="YOLO Format (outputs/yolo_dataset/)\n- Normalized [0, 1] polygon coords\n- Generates data.yaml"];
            Split -> PytorchDS;
            Split -> YoloDS;
        }
    }

    subgraph cluster_training_loop {
        label="2. Training Engine & Architecture";
        style="solid";
        color="black";
        
        subgraph cluster_models {
            label="Model Registries";
            style="dashed";
            PyTorchModels [label="Deep Learning Models\n(UNet, SegFormer, DeepLabV3, SOTA)"];
            UltralyticsModels [label="Ultralytics Models\n(YOLOv8, YOLOv11, RT-DETR)"];
        }

        Prep [label="Data Pipeline Preprocessing\n- Resize (e.g. 512x512)\n- Tensor Normalization [0, 1]"];
        
        PytorchDS -> PyTorchModels [label=" Custom Dataloader"];
        YoloDS -> UltralyticsModels;

        PyTorchModels -> Prep;
        UltralyticsModels -> Prep;

        LossFuncs [label="Loss Functions\n- Default: BCEWithLogits + Dice\n- Combined: BCE+Dice+Boundary+Lovász", shape=note];
        Optim [label="Optimizer & Scheduling\n- AdamW (default), SGD, RMSprop\n- Cosine Annealing, Step, Plateau", shape=note];
        
        Backward [label="Training Loop & Backpropagation\n- FP32 Loss Computation\n- AMP (Auto Mixed Precision)\n- Gradient Clipping"];
        
        HW [label="Hardware Profiling Thread\n- Samples per 100ms\n- GPU VRAM, GPU Utilizations, CPU, RAM", shape=cylinder];

        Prep -> Backward [label=" Forward Phase"];
        LossFuncs -> Backward;
        Optim -> Backward;
        Backward -> HW [style="dotted", label=" Monitors"];
    }

    subgraph cluster_eval {
        label="3. Evaluation, Benchmarking & Output";
        style="solid";
        color="black";
        
        ValLoop [label="Validation Loop\n- No-grad forward pass\n- Computes: IoU, Dice, F1-Score"];
        Checkpoint [label="Model Checkpointing\n- Saves best_model.pt/.pth\n- Outputs to: outputs/results/"];
        Benchmark [label="Inference Benchmark Runner\n- Contour completeness, Edge-alignment\n- Latency & FPS throughput"];
        Report [label="Report & Visualizations\n- loss_curves.png, iou_curves.png\n- JSON statistical ranking", shape=folder];

        Backward -> ValLoop [label=" End of Epoch"];
        ValLoop -> Checkpoint [label=" If IoU improves"];
        Checkpoint -> Benchmark;
        Benchmark -> Report;
    }
}
